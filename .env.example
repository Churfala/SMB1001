# =============================================================================
# ControlCheck – Environment Configuration
# Copy this file to .env and fill in all values before running docker compose
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=smb1001
DB_USER=smb1001user
# Use a strong random password in production
DB_PASSWORD=changeme_strong_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# Uncomment and set if your Redis requires authentication
# REDIS_PASSWORD=changeme_redis_password

# -----------------------------------------------------------------------------
# JWT Authentication
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=changeme_jwt_secret_must_be_at_least_32_characters_long
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=changeme_refresh_secret_must_be_at_least_32_characters_long
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Token Encryption (AES-256-GCM)
# Generate with: openssl rand -hex 32   (produces 64-char hex = 32 bytes)
# This key encrypts OAuth tokens stored in the database
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=changeme_64_char_hex_string_for_aes256_encryption_key_here00

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------------
# Frontend (Vite build-time variable)
# The /api prefix is stripped by Nginx and proxied to the API service
# -----------------------------------------------------------------------------
VITE_API_URL=/api

# -----------------------------------------------------------------------------
# Entra ID SSO (for MSP staff login via Microsoft)
# Register an app at https://portal.azure.com → Entra ID → App registrations
# Redirect URI type: Web, value: https://YOUR_API_DOMAIN/auth/entra/callback
# Grant delegated permission: openid, profile, email
# -----------------------------------------------------------------------------
FRONTEND_URL=https://controlcheck.globaltechnology.nz
ENTRA_TENANT_ID=your-azure-tenant-id
ENTRA_CLIENT_ID=your-app-registration-client-id
ENTRA_CLIENT_SECRET=your-app-registration-client-secret
ENTRA_REDIRECT_URI=https://controlcheckapi.globaltechnology.nz/auth/entra/callback
# Which ControlCheck tenant SSO users land in (must exist in DB)
ENTRA_SSO_TENANT_SLUG=msp-admin
# Set to true to auto-create a user record on first SSO login (role: auditor)
ENTRA_AUTO_PROVISION=true

# -----------------------------------------------------------------------------
# Microsoft 365 OAuth (per-tenant – stored in DB, not here)
# The redirect URI must be registered in your Entra ID app registration
# -----------------------------------------------------------------------------
M365_REDIRECT_URI=http://localhost/api/integrations/m365/callback

# -----------------------------------------------------------------------------
# Worker
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Email Notifications (optional – leave blank to disable)
# Supports any SMTP server (Office 365, Gmail SMTP, SendGrid, Mailgun, etc.)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ControlCheck <noreply@globaltechnology.nz>
